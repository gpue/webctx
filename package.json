{
	"name": "webctx",
	"version": "0.1.0",
	"description": "Browser-based element selection, click automation, and screenshotting tool for agentic web app improvement",
	"type": "module",
	"main": "dist/electron/main.js",
	"bin": {
		"webctx": "dist/cli/index.js"
	},
	"scripts": {
		"dev": "electron .",
		"build": "tsup",
		"start": "electron dist/electron/main.js",
		"serve": "node dist/mcp/server.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"quality": "npm run typecheck && npm run lint && npm run test",
		"deadcode": "knip",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.1",
		"commander": "^13.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@playwright/test": "^1.52.0",
		"@vitest/coverage-v8": "^3.1.3",
		"electron": "^35.0.1",
		"knip": "^5.57.2",
		"lefthook": "^1.11.13",
		"tsup": "^8.5.0",
		"typescript": "^5.8.3",
		"vitest": "^3.1.3"
	},
	"engines": {
		"node": ">=20"
	}
}
